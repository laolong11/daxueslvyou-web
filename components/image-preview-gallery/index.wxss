.cover-list {
  margin-top: 16rpx;
}

.cover-swiper {
  width: 100%;
  height: 520rpx;
  border-radius: 12rpx;
  background: #0f172a;
}

.cover-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover {
  width: 100%;
  height: 100%;
  display: block;
}

.preview-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.preview-top {
  padding: 56rpx 24rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #ffffff;
}

.preview-close {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.preview-count {
  font-size: 24rpx;
}

.preview-swiper {
  flex: 1;
  min-height: 0;
}

.preview-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 12rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx 28rpx;
  color: #ffffff;
  border-top: 1rpx solid rgba(148, 163, 184, 0.3);
  background: rgba(15, 23, 42, 0.74);
}

.preview-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.preview-text {
  min-width: 0;
}

.preview-name {
  font-size: 28rpx;
  font-weight: 600;
}

.preview-line {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(226, 232, 240, 0.95);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
