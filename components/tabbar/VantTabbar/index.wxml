<view class="tabbar-wrap">
  <van-tabbar active="{{active}}" active-color="#0f766e" inactive-color="#7b8794" bind:change="onChange">
    <van-tabbar-item icon="home-o">首页</van-tabbar-item>
    <van-tabbar-item icon="friends-o">拼团</van-tabbar-item>
    <van-tabbar-item icon="notes-o">攻略</van-tabbar-item>
    <van-tabbar-item icon="bell" info="{{messageInfo}}">消息</van-tabbar-item>
    <van-tabbar-item icon="manager-o">我的</van-tabbar-item>
  </van-tabbar>
</view>
