.app-footer {
  padding: 28rpx 24rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #94a3b8;
}

.app-footer__icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  margin-bottom: 10rpx;
}

.app-footer__name {
  font-size: 24rpx;
  color: #475569;
  font-weight: 600;
}

.app-footer__meta,
.app-footer__slogan {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.6;
}
