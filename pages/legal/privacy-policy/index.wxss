.legal-page {
  padding-bottom: 32rpx;
}

.legal-card {
  padding: 24rpx;
}

.legal-intro {
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.7;
}

.legal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.legal-meta {
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  color: #64748b;
  font-size: 22rpx;
}

.legal-section-title {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.legal-text {
  margin-top: 8rpx;
  color: #334155;
  font-size: 25rpx;
  line-height: 1.8;
}

.legal-footnote {
  margin-top: 20rpx;
  color: #64748b;
  font-size: 22rpx;
}
