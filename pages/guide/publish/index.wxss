.stepper-row {

  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stepper-label {
  color: #323233;
  font-size: 28rpx;
}

.upload-row {
  padding: 0 0 20rpx;
}

.upload-tip {
  margin-top: 8rpx;
  margin-bottom: 10rpx;
  color: #475569;
  font-size: 24rpx;
}

.redirect-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at top, rgba(14, 165, 233, 0.12), transparent 42%);
}

.redirect-card {
  width: calc(100% - 64rpx);
}

.redirect-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.redirect-desc {
  margin-top: 10rpx;
  margin-bottom: 18rpx;
  color: #64748b;
  font-size: 24rpx;
}

.redirect-loading {
  margin-bottom: 18rpx;
  color: #0f766e;
  font-size: 24rpx;
}

.redirect-btn {
  height: 84rpx;
  line-height: 84rpx;
  --van-button-border-radius: 999rpx;
}
