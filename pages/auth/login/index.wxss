/* pages/index/index.wxss */
.login-screen {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(14, 165, 233, 0.14), transparent 40%),
    #f3f4f6;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 30vh;
}

.brand-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 118, 110, 0.18);
}

.brand-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2937;
}

.brand-sub {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.login-panel {
  padding: 0 48rpx;
  margin-bottom: 5vh;
}

.login-tip-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.login-tip-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.login-tip-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.agree-row {
  margin-top: 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  color: #374151;
  font-size: 24rpx;
}
.agree-text-wrap {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4rpx;
  line-height: 1.7;
}
.agree-link {
  color: #0f766e;
  text-decoration: underline;
}

.agree-tip {
  margin: -10rpx 0 16rpx;
  color: #64748b;
  font-size: 22rpx;
}

.agree-checkbox {
  transform: scale(0.88);
  margin-top: 2rpx;
}


.login-btn button {
  --button-border-radius: 999rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 10rpx;
}

.skip-btn {
  height: 82rpx;
  line-height: 82rpx;
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 8rpx);
}