.skeleton-list {
	display: flex;
	flex-direction: column;
	gap: 18rpx;
}

.skeleton-banner,
.skeleton-card {
	pointer-events: none;
}

.skeleton-banner {
	padding: 18rpx;
}

.sk-block,
.sk-line {
	background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 45%, #e2e8f0 65%);
	background-size: 220% 100%;
	animation: skShimmer 1.4s ease-in-out infinite;
	border-radius: 12rpx;
}

.sk-line {
	height: 24rpx;
}

.sk-banner-title {
	width: 180rpx;
	margin-bottom: 14rpx;
}

.sk-banner-main {
	height: 280rpx;
	border-radius: 16rpx;
}

.sk-thumb {
	height: 220rpx;
	margin-bottom: 12rpx;
	border-radius: 10rpx;
}

.sk-title {
	width: 76%;
}

.sk-desc {
	width: 92%;
	margin-top: 12rpx;
}

.sk-row {
	margin-top: 14rpx;
	display: flex;
	align-items: center;
	gap: 14rpx;
}

.sk-countdown-label {
	width: 120rpx;
}

.sk-countdown-value {
	width: 180rpx;
}

.sk-meta {
	width: 58%;
	margin-top: 12rpx;
}

.banner-title {
	font-size: 30rpx;
	font-weight: 700;
	color: #0f172a;
	margin-bottom: 12rpx;
}

.notice-wrap {
	padding: 0;
	overflow: hidden;
}

.top-swiper {
	height: 280rpx;
	border-radius: 16rpx;
	overflow: hidden;
}

.top-slide {
	position: relative;
	width: 100%;
	height: 100%;
}

.top-image {
	width: 100%;
	height: 100%;
}

.top-mask {
	position: absolute;
	left: 0;
	right: 0;
	bottom: 0;
	padding: 16rpx;
	background: linear-gradient(to top, rgba(2, 6, 23, 0.72), rgba(2, 6, 23, 0));
}

.top-destination {
	font-size: 24rpx;
	color: rgba(226, 232, 240, 0.95);
}

.top-text {
	margin-top: 4rpx;
	font-size: 28rpx;
	font-weight: 700;
	color: #ffffff;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.home-thumb {
	width: 100%;
	border-radius: 10rpx;
	display: block;
}

.thumb-wrap {
	position: relative;
	margin-bottom: 10rpx;
}

.official-badge {
	position: absolute;
	top: 10rpx;
	right: 10rpx;
	padding: 4rpx 12rpx;
	border-radius: 999rpx;
	font-size: 20rpx;
	line-height: 1.2;
	font-weight: 700;
	color: #b45309;
	background: rgba(254, 243, 199, 0.95);
	border: 1px solid rgba(245, 158, 11, 0.55);
	z-index: 2;
}

.card-title-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 10rpx;
}

.card-countdown {
	margin-top: 10rpx;
	display: flex;
	align-items: center;
	gap: 12rpx;
	flex-wrap: wrap;
}

.card-countdown-label {
	color: #0f766e;
	font-size: 24rpx;
}

.card-countdown-ended {
	color: #dc2626;
	font-size: 22rpx;
}

.ad-dialog__title {
	font-size: 32rpx;
	font-weight: 700;
	color: #0f172a;
	margin-bottom: 12rpx;
}

.ad-dialog__image {
	width: 100%;
	height: 320rpx;
	border-radius: 12rpx;
	margin-bottom: 12rpx;
}

.ad-dialog__content {
	font-size: 26rpx;
	line-height: 1.6;
	color: #334155;
	margin-bottom: 10rpx;
}

.ad-dialog__time {
	font-size: 22rpx;
	color: #64748b;
	margin-bottom: 16rpx;
}

@keyframes skShimmer {
	0% {
		background-position: 100% 0;
	}

	100% {
		background-position: -100% 0;
	}
}
