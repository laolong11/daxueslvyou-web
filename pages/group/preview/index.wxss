.preview-page {
  min-height: 100vh;
  background: #0b12202c;
  color: #ffffff;
  display: flex;
  flex-direction: column;
}

.top-bar {
  padding: 48rpx 24rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.close-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 24rpx;
}

.indicator {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.loading-wrap {
  padding: 12rpx;
  flex: 1;
}

.preview-skeleton {
  height: 100%;
  display: flex;
  flex-direction: column;
  pointer-events: none;
}

.sk-block,
.sk-line,
.sk-avatar {
  background: linear-gradient(90deg, rgba(148, 163, 184, 0.32) 25%, rgba(226, 232, 240, 0.45) 45%, rgba(148, 163, 184, 0.32) 65%);
  background-size: 220% 100%;
  animation: skShimmer 1.4s ease-in-out infinite;
}

.sk-image {
  flex: 1;
  border-radius: 18rpx;
}

.sk-panel {
  margin-top: 12rpx;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(11, 18, 32, 0.72);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.sk-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
}

.sk-meta {
  flex: 1;
}

.sk-line {
  height: 22rpx;
  border-radius: 12rpx;
}

.sk-name {
  width: 42%;
}

.sk-extra {
  width: 68%;
  margin-top: 12rpx;
}

.preview-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.preview-swiper {
  flex: 1;
  min-height: 0;
}

.slide-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 12rpx 0;
  box-sizing: border-box;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.publisher-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(11, 18, 32, 0.84);
  border-top: 1rpx solid rgba(148, 163, 184, 0.28);
}

.publisher-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.publisher-meta {
  min-width: 0;
}

.publisher-name {
  font-size: 28rpx;
  font-weight: 600;
}

.publisher-extra {
  margin-top: 6rpx;
  color: rgba(226, 232, 240, 0.92);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@keyframes skShimmer {
  0% {
    background-position: 100% 0;
  }

  100% {
    background-position: -100% 0;
  }
}
